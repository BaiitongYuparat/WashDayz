// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum RiderStatus {
  AVAILABLE
  DELIVERING
}

enum OrderStatus {
  WASHING
  DELIVERING
  WAITING
  FINISHED
}

model User {
  user_id    Int           @id @default(autoincrement())
  googleId   String?       @unique
  name       String
  email      String        @unique
  password   String
  phone      String
  addresses  UserAddress[]
  orders     Order[]
  created_at DateTime      @default(now())
  updated_at DateTime      @default(now()) @updatedAt
}

model UserAddress {
  address_id    Int    @id @default(autoincrement())
  user_id       Int
  label         String
  receiver_name String
  district      String
  postal_code   String
  user     User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Rider {
  rider_id      Int         @id @default(autoincrement())
  name          String
  phone         String
  license_plate String
  status        RiderStatus @default(AVAILABLE)
  orders        Order[]
}

model Branch {
  branch_id   Int     @id @default(autoincrement())
  branch_name String
  queue       Int?
}

model MainService {
  main_service_id Int         @id @default(autoincrement())
  name            String
  description     String?
  price_per_unit  Float
  orderItems      OrderItem[]
}

model AddonService {
  addon_service_id Int              @id @default(autoincrement())
  name             String
  description      String?
  price            Float
  orderItemAddons  OrderItemAddon[]
}

model Order {
  order_id  Int         @id @default(autoincrement())
  user_id   Int
  rider_id  Int?
  branch_id Int
  service   String?
  pieces    Int
  price     Float
  status    OrderStatus @default(WAITING)

  user   User   @relation(fields: [user_id], references: [user_id] ,onDelete: Cascade)
  rider  Rider? @relation(fields: [rider_id], references: [rider_id])
  branch Branch @relation(fields: [branch_id], references: [branch_id])

  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  order_item_id   Int              @id @default(autoincrement())
  order_id        Int
  main_service_id Int
  quantity        Int
  subtotal        Float
  order           Order            @relation(fields: [order_id], references: [order_id])
  mainService     MainService      @relation(fields: [main_service_id], references: [main_service_id])
  addons          OrderItemAddon[]
}

model OrderItemAddon {
  id               Int          @id @default(autoincrement())
  order_item_id    Int
  addon_service_id Int
  orderItem        OrderItem    @relation(fields: [order_item_id], references: [order_item_id])
  addonService     AddonService @relation(fields: [addon_service_id], references: [addon_service_id])
}

model Payment {
  payment_id      Int       @id @default(autoincrement())
  order_id        Int       @unique
  payment_method  String
  status          String
  transaction_ref String?
  created_at      DateTime  @default(now())
  paid_at         DateTime?
  order           Order     @relation(fields: [order_id], references: [order_id])
}


