// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum RiderStatus {
  AVAILABLE
  DELIVERING
}

enum OrderStatus {
  WASHING
  DELIVERING
  WAITING
  FINISHED
}

enum RoleStatus {
 USER
 ADMIN
}



model User {
  user_id    String   @id @default(uuid())
  googleId String?  @unique
  name       String
  email      String   @unique
  password   String?
  phone      String?
  role RoleStatus @default(USER)
  addresses  UserAddress[]
  orders     Order[]
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  
}

model UserAddress {
  address_id    String @id @default(uuid())
  user_id       String
  label         String
  receiver_name String
  district     String
  subDistrict String
  province String
  postal_code  String
  details      String?
  lat   Float?
  lng Float?
  phone String
  user User @relation(fields: [user_id], references: [user_id])
}

model Rider {
  rider_id      String @id @default(uuid())
  name          String
  phone         String
  license_plate String
  status        RiderStatus @default(AVAILABLE)
  orders        Order[]
}

model Branch {
  branch_id   String @id @default(uuid())
  branch_name String
  queues Queue[]
  orders Order[]
}

model MainService {
  main_service_id String @id @default(uuid())
  name            String
  description     String?
  price_per_unit  Float
  orderItems      OrderItem[]
}

model AddonService {
  addon_service_id String @id @default(uuid())
  name             String
  description      String?
  price            Float
  orderItemAddons  OrderItemAddon[]
}

model Order {
  order_id   String @id @default(uuid())
  user_id    String
  rider_id   String?
  branch_id  String
  pieces     Int
  price      Float
  queue Queue?
  status     OrderStatus @default(WAITING)
  user   User   @relation(fields: [user_id], references: [user_id])
  rider  Rider? @relation(fields: [rider_id], references: [rider_id])
  branch Branch @relation(fields: [branch_id], references: [branch_id])

  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  order_item_id   String @id @default(uuid())
  order_id        String
  main_service_id String
  quantity        Int
  subtotal        Float
  order           Order            @relation(fields: [order_id], references: [order_id])
  mainService     MainService      @relation(fields: [main_service_id], references: [main_service_id])
  addons          OrderItemAddon[]
}

model OrderItemAddon {
  id               String @id @default(uuid())
  order_item_id    String
  addon_service_id String
  orderItem        OrderItem    @relation(fields: [order_item_id], references: [order_item_id])
  addonService     AddonService @relation(fields: [addon_service_id], references: [addon_service_id])
}

model Payment {
  payment_id      String @id @default(uuid())
  order_id        String      @unique
  payment_method  String
  status          String
  created_at DateTime @default(now())
  paid_at    DateTime?
  order Order @relation(fields: [order_id], references: [order_id])
  updated_at DateTime @default(now()) @updatedAt
}

model Queue {
  queue_id     String @id @default(uuid())
  order_id     String @unique
  branch_id    String

  queue_number Int

  created_at   DateTime @default(now())
  called_at    DateTime?
  finished_at  DateTime?


  order  Order  @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  branch Branch @relation(fields: [branch_id], references: [branch_id])

  @@unique([branch_id, queue_number])
  @@index([branch_id])
}